# Panes claurst-native local environment template.
# Copy this file to `.env` and fill only the providers you use.
# Values from the OS environment take precedence over `.env`.

# Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional third-party/proxy endpoint.
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_BASE=https://api.anthropic.com

# OpenAI official API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_API_BASE=https://api.openai.com

# Generic OpenAI-compatible provider
# Use these when the provider accepts /v1/chat/completions.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
# OPENAI_COMPATIBLE_API_BASE=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api
# OPENROUTER_API_BASE=https://openrouter.ai/api

# Ollama local OpenAI-compatible endpoint
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Last-resort base URL override used by compatible providers.
# Prefer provider-specific variables above when possible.
# CLAURST_API_BASE=

# CueLight live verification
CUELIGHT_TOKEN=
CUELIGHT_WORKSPACE_ROOT=
CUELIGHT_SOURCE_FILE=
